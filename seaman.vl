                <Pad Id="PS12zOh5Go1OWHQ4yh36FK" Bounds="1781,353,125,19" ShowValueBox="true" isIOBox="true" Value="world wettest place">
                  <p:TypeAnnotation LastCategoryFullName="Primitive" LastDependency="VL.CoreLib.vl">
                    <Choice Kind="TypeFlag" Name="String" />
                  </p:TypeAnnotation>
                  <p:ValueBoxSettings>
                    <p:fontsize p:Type="Int32">9</p:fontsize>
                    <p:stringtype p:Assembly="VL.Core" p:Type="VL.Core.StringType">Comment</p:stringtype>
                  </p:ValueBoxSettings>
                </Pad>
                <Pad Id="NOrKjeheJc3N1X7ghZivjY" Bounds="1668,373,500,130" ShowValueBox="true" isIOBox="true" Value="With an astounding average annual rainfall of 11,871 millimeters, the town of Mawsynram in northeast India is Earth's wettest place.This town is located in the southern edge of the East Khasi Hills overlooking the plains of the neighboring country of Bangladesh. Moisture from the Bay of Bengal collects here due to the typical shape and orography of the catchment area, resulting in heavy rains. Featuring a mildly cool climate of no more than the low 20s degrees Celsius in the summer, Mawsynram truly is a fascinating and absolutely soaked locale.">
                  <p:TypeAnnotation LastCategoryFullName="Primitive" LastDependency="VL.CoreLib.vl">
                    <Choice Kind="TypeFlag" Name="String" />
                  </p:TypeAnnotation>
                  <p:ValueBoxSettings>
                    <p:fontsize p:Type="Int32">9</p:fontsize>
                    <p:stringtype p:Assembly="VL.Core" p:Type="VL.Core.StringType">Comment</p:stringtype>
                  </p:ValueBoxSettings>
                </Pad>
