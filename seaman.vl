                <Pad Id="VMlilvXxLDZN7E0F9N0Nok" Bounds="439,393,506,109" ShowValueBox="true" isIOBox="true" Value="Death Valley National Park is a large park in a low area below sea level. It is famous for being really hot, dry, and low. Death Valley is the driest place in North America and the hottest place in the world. It’s like a long, narrow hole in the ground, 282 feet (86 m) below sea level. ">
                  <p:TypeAnnotation LastCategoryFullName="Primitive" LastDependency="VL.CoreLib.vl">
                    <Choice Kind="TypeFlag" Name="String" />
                  </p:TypeAnnotation>
                  <p:ValueBoxSettings>
                    <p:fontsize p:Type="Int32">9</p:fontsize>
                    <p:stringtype p:Assembly="VL.Core" p:Type="VL.Core.StringType">Comment</p:stringtype>
                  </p:ValueBoxSettings>
                </Pad>
