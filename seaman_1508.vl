                <Pad Id="K5s0hOyiTepMom5Tecl6ms" Bounds="997,390,632,44" ShowValueBox="true" isIOBox="true" Value="world coolest place In the southern hemisphere, the Pole of Cold is currently located in Antarctica, at the Russian (formerly Soviet) Antarctic station Vostok at 78°28′S 106°48′E.">
                  <p:TypeAnnotation LastCategoryFullName="Primitive" LastDependency="VL.CoreLib.vl">
                    <Choice Kind="TypeFlag" Name="String" />
                  </p:TypeAnnotation>
                  <p:ValueBoxSettings>
